	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#7C98A1",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword",
				"storage",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#e7cbac",
			}
		},
		{
			"name": "Function and Method Names",
			"scope": [
				"entity.name.function",
				"meta.function-call",
				"variable.function",
				"support.function",
				"entity.name.method"
			],
			"settings": {
				"foreground": "#f5e6de"
			}
		},
		{
			"name": "Variables and Properties",
			"scope": [
				"variable",
				"meta.definition.variable",
				"support.variable",
				"variable.other.property"
			],
			"settings": {
				"foreground": "#f5e6de"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"constant.character",
				"constant.escape"
			],
			"settings": {
				"foreground": "#8edac5"
			}
		},
		{
			"name": "Types",
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"support.type",
				"support.class"
			],
			"settings": {
				"foreground": "#e7cbac"
			}
		},
		{
			"name": "Numbers and Booleans",
			"scope": [
				"constant.numeric",
				"constant.language.boolean",
				"constant.language"
			],
			"settings": {
				"foreground": "#f6c198"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation",
				"meta.brace",
				"meta.delimiter"
			],
			"settings": {
				"foreground": "#f5e6de"
			}
		},
		{
			"name": "Invalid",
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#fa7578"
			}
		}
	],
	"semanticTokenColors": {
		"comment": {
			"foreground": "#7C98A1",
			"italic": true
		},
		"keyword": {
			"foreground": "#e7cbac",
		},
		"string": "#8edac5",
		"number": "#f6c198",
		"boolean": "#f6c198",
		"function": "#f5e6de",
		"method": "#f5e6de",
		"variable": "#f5e6de",
		"parameter": "#f5e6de",
		"property": "#f5e6de",
		"type": "#e7cbac",
		"class": "#e7cbac",
		"interface": "#e7cbac",
		"enum": "#e7cbac",
		"enumMember": "#8edac5",
		"operator": "#f5e6de"
	}
}
